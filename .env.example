# treesearch-service — environment
#
# Copy to .env for local development. In deployment these values come from
# deploy-kit/.env.deploy, which deploy.sh stages as .env next to docker-compose.yml.
#
# NOTE: .env is gitignored. Never commit a real credential — this repo is PUBLIC.

# Required. The service refuses to start without it (src/db.py).
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5433/<database>

# Required for the test suite. MUST point at a throwaway database —
# the tests create, truncate and drop tables.
TEST_DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5433/treesearch_test

# Upstream scraper-service (forums, Kannapedia, Leafly, DuckDuckGo).
SCRAPER_SERVICE_URL=http://10.0.0.16:3031

# Vision models used to filter scraped forum images down to plant photos.
JETSON_VLLM_URL=http://10.0.0.30:8000
DGX_SPARK_VLLM_URL=http://10.0.0.141:8000

PORT=8005
